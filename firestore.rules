rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isValidUsername(username) {
      return username is string
        && username.size() >= 2
        && username.size() <= 24
        && username.matches('^[A-Za-z0-9 ._-]+$');
    }

    function gameDoc() {
      return get(/databases/$(database)/documents/settings/game);
    }

    match /settings/game {
      allow read: if true;

      // Admin protection is intentionally handled by the client-side passcode
      // for this low-risk project. Treat these writes as convenience-gated,
      // not strongly secured.
      allow create, update, delete: if true;
    }

    match /participants/{participantId} {
      allow read: if true;
      allow create, update: if request.resource.data.participantId == participantId
        && isValidUsername(request.resource.data.username)
        && request.resource.data.keys().hasOnly([
          'participantId',
          'username',
          'usernameKey',
          'usernameDocId',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if true;
    }

    match /usernames/{usernameId} {
      allow read: if true;
      allow create, update: if isValidUsername(request.resource.data.username)
        && request.resource.data.participantId is string
        && request.resource.data.keys().hasOnly([
          'participantId',
          'username',
          'usernameKey',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if true;
    }

    match /rounds/{roundId} {
      allow read: if true;
      allow create, update, delete: if true;

      match /presses/{participantId} {
        allow read: if true;
        allow create: if gameDoc().data.isButtonEnabled == true
          && gameDoc().data.roundId == roundId
          && exists(/databases/$(database)/documents/participants/$(participantId))
          && get(/databases/$(database)/documents/participants/$(participantId)).data.username == request.resource.data.username
          && request.resource.data.participantId == participantId
          && request.resource.data.roundId == roundId
          && isValidUsername(request.resource.data.username)
          && request.resource.data.pressedAt == request.time
          && request.resource.data.createdAt == request.time
          && !exists(/databases/$(database)/documents/rounds/$(roundId)/presses/$(participantId))
          && request.resource.data.keys().hasOnly([
            'participantId',
            'username',
            'usernameKey',
            'roundId',
            'roundNumber',
            'roundStartedAt',
            'pressedAt',
            'createdAt'
          ]);
        allow update: if false;
        allow delete: if true;
      }
    }
  }
}
